# Slave (account executor) — one instance per broker account.
#
# This process holds NO strategy logic. It receives resolved order
# instructions from Master over HTTP, runs them through local strategy-blind
# risk gates, and submits via this account's own broker credentials.

# Required. Distinct, stable id for this account, e.g. S1-ZAK-INDIVIDUAL,
# S1-ZAK-IRA, S2-ZAK-INDIVIDUAL. Isolates this process's state under
# ~/.tradebot/<ACCOUNT_ID>/ — never share an account id across two
# processes. The launchd service label is derived from this account id.
# For multiple accounts on the same machine, copy this file to a unique
# name such as .env.s1-zak-individual or .env.s1-zak-ira.
TRADEBOT_ACCOUNT_ID=PASTE_ACCOUNT_ID

# Broker account wrapper type. Keep this separate from TRADEBOT_LIVE:
# INDIVIDUAL can be paper or live, depending on TRADEBOT_LIVE.
# Other supported values: IRA, ROTH_IRA, JOINT, TRUST.
TRADEBOT_ACCOUNT_TYPE=INDIVIDUAL

ALPACA_API_KEY_ID=PASTE_PAPER_KEY_ID
ALPACA_API_SECRET_KEY=PASTE_PAPER_SECRET_KEY
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Safety flag — must be set to 1 to enable live trading. Default is paper.
TRADEBOT_LIVE=0
# Required only for live trading:
# TRADEBOT_CONFIRM_LIVE_ALPACA=I_UNDERSTAND_THIS_USES_REAL_MONEY

# HTTP endpoint this process listens on for instructions from Master.
# Keep bound to a private network (e.g. Tailscale IP), never public.
# Pick a unique port per account/service instance on the same machine.
# SERVICE_HOST=127.0.0.1
# SERVICE_PORT=8788

# Required before onboarding or remote use. Generate a unique 256-bit secret
# per account and store the same value in Master's protected Slave registry.
# TRADEBOT_TRANSPORT_HMAC_SECRET=PASTE_64_HEX_CHAR_SECRET

# Optional tighter per-account limits. Values above the hardcoded guardrails
# are rejected.
# TRADEBOT_MAX_RISK_PER_TRADE_USD=100
# TRADEBOT_MAX_TOTAL_OPEN_RISK_USD=500
# TRADEBOT_MAX_CONCURRENT_POSITIONS=5
